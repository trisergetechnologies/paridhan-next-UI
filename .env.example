# Optional. If unset, the browser calls same-origin /api/v1 (see next.config rewrites).
# May be host-only (http://localhost:4600) — /api/v1 is appended automatically.
# Production default: API gateway on 4601 (see paridhan-api-gateway).
NEXT_PUBLIC_API_URL=http://localhost:4601/api/v1

# Target for Next.js rewrites: /api/v1/* → backend. Default http://127.0.0.1:4600
# API_PROXY_TARGET=http://127.0.0.1:4600

# Optional storefront copy (footer & contact). Use | to separate multiple lines for address/hours.
# NEXT_PUBLIC_CONTACT_EMAIL=hello@example.com,support@example.com
# NEXT_PUBLIC_CONTACT_PHONE=+91 00000 00000
# NEXT_PUBLIC_CONTACT_ADDRESS=Line one|Line two|India
# NEXT_PUBLIC_CONTACT_HOURS=Mon–Sat: 10am–6pm|Sun: closed
# NEXT_PUBLIC_SOCIAL_FACEBOOK=
# NEXT_PUBLIC_SOCIAL_INSTAGRAM=
# NEXT_PUBLIC_SOCIAL_TWITTER=
