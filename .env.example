# Base URL for the Paridhan API (no trailing slash).
# Must include the /api/v1 prefix used in paridhan-backend (server.js).
# Use the API gateway in dev (port 4000). For direct backend access use http://localhost:5000/api/v1
# Home hero: GET …/public/hero. Contact form: POST …/public/contact
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
